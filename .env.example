# ZeptoMail (transactional email for the contact form)
# Send Mail token from the ZeptoMail agent (without the "Zoho-enczapikey " prefix)
ZEPTOMAIL_TOKEN=
# Verified sender address on the agent's domain
ZEPTOMAIL_FROM_ADDRESS=no-reply@mahlangu.dev
# Template alias configured in the ZeptoMail dashboard
ZEPTOMAIL_TEMPLATE_ALIAS=portfolio-contact
# Inbox that receives contact form submissions
CONTACT_TO_ADDRESS=
